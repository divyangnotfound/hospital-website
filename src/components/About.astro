---
import hospitalInfo from '../data/hospital-info.json';
---

<section id="about" class="py-12 lg:py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

      <!-- Text Content -->
      <div class="slide-left">

        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral mb-4 leading-tight">
          {hospitalInfo.about.title.split(' ').map((word: string, i: number) => (
            i >= hospitalInfo.about.title.split(' ').length - 2
              ? <span class="text-secondary"> {word}</span>
              : <span> {word}</span>
          ))}
        </h2>

        {hospitalInfo.about.paragraphs.map((p: string) => (
          <p class="text-neutral/70 text-base sm:text-lg leading-relaxed mb-4">{p}</p>
        ))}


      </div>

      <!-- Image -->
      <div class="slide-right relative">
        <div class="relative rounded-3xl overflow-hidden shadow-2xl">
          <img
            src="https://lh3.googleusercontent.com/p/AF1QipPm4T6AcUfmdFOfh1a7sdczBNBltQ963mdlbbOy=w243-h174-n-k-no-nu"
            alt="Prayosha Hospital Interior"
            class="w-full h-[400px] lg:h-[500px] object-cover"
            loading="lazy"
          />
          <!-- Floating card -->
          <div class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-xl p-5 border-t border-light-gray/60 flex items-center justify-center gap-5 sm:gap-6 group hover:bg-white transition-colors duration-300">
            <div class="relative w-12 h-12 sm:w-14 sm:h-14 bg-gradient-to-br from-primary to-secondary rounded-2xl flex items-center justify-center shrink-0 shadow-lg shadow-primary/20 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6 sm:w-7 sm:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h2l1 3 2-6 1 3h2" />
              </svg>
            </div>
            <div>
              <div class="font-extrabold text-neutral text-lg sm:text-xl leading-tight mb-0.5">Trusted Healing</div>
              <div class="text-sm font-medium text-neutral/60">Thousands of lives saved</div>
            </div>
          </div>
        </div>

        <!-- Decorative dot grid -->
        <div class="absolute -top-6 -right-6 w-24 h-24 opacity-20" style="background-image: radial-gradient(circle, #51C2B8 1.5px, transparent 1.5px); background-size: 12px 12px;"></div>
      </div>
    </div>
  </div>
</section>
