---
import hospitalInfo from '../data/hospital-info.json';
---

<section id="contact" class="py-16 lg:py-24 relative bg-[#F2F3F4] overflow-hidden">
  <!-- Subtle gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#F2F3F4] via-white/50 to-[#F2F3F4]"></div>
  <div class="absolute top-0 left-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-secondary/5 rounded-full blur-3xl translate-y-1/2 translate-x-1/4"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral mb-4">
        Visit Us <span class="text-primary">Anytime</span>
      </h2>
      <p class="text-neutral/60 text-base sm:text-lg">
        Your health is our priority — reach out or walk in, we're always open.
      </p>
    </div>

    <!-- Main Grid: Info Left, Map Right -->
    <div class="grid lg:grid-cols-2 gap-8 items-stretch fade-in">

      <!-- Left: Contact Info -->
      <div class="flex flex-col gap-6">

        <!-- Emergency Banner -->
        <a
          href={`tel:${hospitalInfo.contact.emergency}`}
          class="group flex items-center gap-5 bg-white border border-red-100 rounded-2xl p-5 hover:bg-red-50/50 transition-all duration-300 shadow-sm"
        >
          <div class="w-14 h-14 bg-red-500 rounded-2xl flex items-center justify-center shrink-0 shadow-lg shadow-red-200 group-hover:scale-105 transition-transform">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-red-500 mb-0.5">Emergency Helpline</div>
            <span class="text-2xl font-extrabold text-neutral group-hover:text-red-600 transition-colors">{hospitalInfo.contact.emergencyDisplay}</span>
          </div>
          <svg class="w-5 h-5 text-red-300 ml-auto group-hover:text-red-500 group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <!-- Address -->
        <a
          href={hospitalInfo.directionsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-5 bg-white border border-light-gray/60 rounded-2xl p-5 hover:border-primary/20 hover:shadow-md transition-all duration-300"
        >
          <div class="w-14 h-14 bg-secondary/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform">
            <svg class="w-7 h-7 text-secondary" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="flex-1">
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral/40 mb-1">Hospital Address</div>
            <p class="text-neutral/70 text-sm leading-relaxed group-hover:text-neutral transition-colors">{hospitalInfo.address.full}</p>
            <span class="inline-flex items-center gap-1 text-primary text-xs font-semibold mt-2 group-hover:gap-2 transition-all">
              Open in Google Maps
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </span>
          </div>
        </a>

        <!-- Hours -->
        <div class="flex items-center gap-5 bg-white border border-light-gray/60 rounded-2xl p-5 shadow-sm">
          <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center shrink-0">
            <svg class="w-7 h-7 text-primary" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-neutral/40 mb-0.5">Working Hours</div>
            <span class="text-lg font-bold text-neutral">{hospitalInfo.opd.timings}</span>
            <p class="text-neutral/50 text-xs mt-0.5">{hospitalInfo.opd.days}</p>
          </div>
          <div class="ml-auto shrink-0">
            <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-600 border border-green-200 text-xs font-bold px-3 py-1.5 rounded-full">
              <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
              Open Now
            </span>
          </div>
        </div>
      </div>

      <!-- Right: Google Map -->
      <div class="rounded-2xl overflow-hidden border border-light-gray shadow-xl min-h-[450px] lg:min-h-0 bg-white">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3686.5!2d73.085!3d22.235!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x395fb943ca3c9763%3A0x48c1cb2be15f197a!2sPrayosha%20Hospital!5e0!3m2!1sen!2sin!4v1773471967870!5m2!1sen!2sin"
          width="100%"
          height="100%"
          style="border:0; min-height: 450px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Prayosha Hospital Location"
        ></iframe>
      </div>

    </div>
  </div>
</section>
