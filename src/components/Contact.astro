---
import hospitalInfo from '../data/hospital-info.json';
---

<section id="contact" class="py-20 lg:py-28 bg-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 fade-in">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        Get In Touch
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral mb-4">
        Location & <span class="text-primary">Contact</span>
      </h2>
      <p class="text-neutral/60 text-base sm:text-lg">
        Visit us or reach out — we're here for you around the clock for emergencies.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10">

      <!-- Contact Info -->
      <div class="space-y-6 fade-in">
        <!-- Emergency Card -->
        <div class="bg-gradient-to-br from-red-50 to-red-100 border border-red-200 rounded-2xl p-6">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-red-500 rounded-2xl flex items-center justify-center shadow-lg shadow-red-200">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-red-600 uppercase tracking-wide">Emergency Contact</div>
              <a href={`tel:${hospitalInfo.contact.emergency}`} class="text-2xl font-extrabold text-red-700 hover:text-red-800">
                {hospitalInfo.contact.emergencyDisplay}
              </a>
            </div>
          </div>
        </div>

        <!-- Address -->
        <div class="bg-light-gray rounded-2xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-secondary/15 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-neutral mb-1">Hospital Address</div>
              <p class="text-neutral/60 text-sm leading-relaxed">{hospitalInfo.address.full}</p>
            </div>
          </div>
        </div>

        <!-- OPD Timings -->
        <div class="bg-light-gray rounded-2xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/15 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-neutral mb-1">OPD Timings</div>
              <p class="text-neutral/60 text-sm">{hospitalInfo.opd.timings}</p>
              <p class="text-neutral/50 text-xs mt-1">{hospitalInfo.opd.days}</p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <a
          href={`tel:${hospitalInfo.contact.callNow}`}
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold text-base px-8 py-4 rounded-full transition-all duration-300 shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:scale-105 w-full justify-center"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Now — {hospitalInfo.contact.callNowDisplay}
        </a>
      </div>

      <!-- Google Maps -->
      <div class="fade-in">
        <div class="rounded-2xl overflow-hidden shadow-xl border border-light-gray h-full min-h-[400px]">
          <iframe
            src={hospitalInfo.mapEmbedUrl}
            width="100%"
            height="100%"
            style="border:0; min-height: 400px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Prayosha Hospital Location"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
