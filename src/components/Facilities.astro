---
import hospitalInfo from '../data/hospital-info.json';

interface Facility {
  name: string;
  description: string;
  icon: string;
}
---

<section id="facilities" class="py-20 lg:py-28 bg-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 fade-in">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        Infrastructure
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral mb-4">
        Advanced <span class="text-primary">Facilities</span>
      </h2>
      <p class="text-neutral/60 text-base sm:text-lg">
        Our hospital is equipped with world-class infrastructure to deliver the highest standard of medical care.
      </p>
    </div>

    <!-- Facilities Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {hospitalInfo.facilities.map((fac: Facility, idx: number) => (
        <div class="fade-in group relative bg-gradient-to-br from-light-gray to-white rounded-2xl p-8 border border-light-gray hover:border-primary/30 transition-all duration-500 hover:shadow-xl">
          <div class="flex items-start gap-5">
            <div class="shrink-0 w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-2xl flex items-center justify-center text-3xl shadow-lg shadow-primary/20 group-hover:scale-110 transition-transform duration-300">
              {fac.icon}
            </div>
            <div>
              <h3 class="text-xl font-bold text-neutral mb-2 group-hover:text-primary transition-colors">
                {fac.name}
              </h3>
              <p class="text-neutral/60 text-sm leading-relaxed">
                {fac.description}
              </p>
            </div>
          </div>

          <!-- Decorative line -->
          <div class="absolute bottom-0 left-8 right-8 h-0.5 bg-gradient-to-r from-primary/0 via-primary/30 to-primary/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      ))}
    </div>

    <!-- Facility image -->
    <div class="mt-12 fade-in">
      <div class="relative rounded-3xl overflow-hidden shadow-2xl">
        <img
          src="/images/facility.png"
          alt="Hospital Facility"
          class="w-full h-[300px] lg:h-[400px] object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-neutral/70 via-transparent to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8">
          <div class="flex flex-wrap gap-3">
            <span class="bg-white/90 backdrop-blur-sm text-neutral text-sm font-semibold px-4 py-2 rounded-full">Modular OT</span>
            <span class="bg-white/90 backdrop-blur-sm text-neutral text-sm font-semibold px-4 py-2 rounded-full">Ventilators</span>
            <span class="bg-white/90 backdrop-blur-sm text-neutral text-sm font-semibold px-4 py-2 rounded-full">24hr Pharmacy</span>
            <span class="bg-white/90 backdrop-blur-sm text-neutral text-sm font-semibold px-4 py-2 rounded-full">CSSD</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
