---
import hospitalInfo from '../data/hospital-info.json';
---

<section id="home" class="relative min-h-[80vh] flex items-center overflow-hidden">
  <!-- Background with overlay -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-bg.webp"
      alt="Prayosha Hospital Building"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-neutral/85 via-neutral/60 to-neutral/30"></div>
  </div>

  <!-- Decorative shapes -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-12">
    <div class="max-w-3xl mx-auto text-center">

      <!-- Headline -->
      <h1 class="fade-in text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-tight mb-6">
        {hospitalInfo.tagline.split(',').map((part: string, i: number) => (
          i === 0
            ? <span>{part},<br /></span>
            : <span class="text-primary">{part}</span>
        ))}
      </h1>

      <!-- Subheadline -->
      <p class="fade-in text-lg sm:text-xl text-white/80 mb-8 max-w-xl mx-auto leading-relaxed">
        {hospitalInfo.subTagline}
      </p>

      <!-- CTA -->
      <div class="fade-in flex flex-wrap gap-4 justify-center">
        <a
          href={`tel:${hospitalInfo.contact.callNow}`}
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold text-base px-8 py-4 rounded-full transition-all duration-300 shadow-2xl shadow-primary/30 hover:shadow-primary/50 hover:scale-105"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Book Appointment
        </a>
      </div>

      <!-- Stats -->
      <div class="fade-in mt-10 grid grid-cols-3 gap-6 max-w-md mx-auto">
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-primary">24/7</div>
          <div class="text-xs sm:text-sm text-white/60 mt-1">ICU & Trauma</div>
        </div>
        <div class="text-center border-x border-white/10">
          <div class="text-3xl sm:text-4xl font-extrabold text-primary">5+</div>
          <div class="text-xs sm:text-sm text-white/60 mt-1">Departments</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-primary">100%</div>
          <div class="text-xs sm:text-sm text-white/60 mt-1">Sterilized OT</div>
        </div>
      </div>
    </div>
  </div>
</section>
