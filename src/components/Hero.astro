---
import hospitalInfo from '../data/hospital-info.json';
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background with overlay -->
  <div class="absolute inset-0">
    <img
      src="/images/IMG-8694.webp"
      alt="Prayosha Hospital Building"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-neutral/85 via-neutral/60 to-neutral/30"></div>
  </div>

  <!-- Decorative shapes -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="fade-in inline-flex items-center gap-2 bg-primary/15 backdrop-blur-sm text-primary px-4 py-2 rounded-full text-sm font-semibold mb-8 border border-primary/20">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        24/7 Emergency & Trauma Care
      </div>

      <!-- Headline -->
      <h1 class="fade-in text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-tight mb-6">
        {hospitalInfo.tagline.split(',').map((part: string, i: number) => (
          i === 0
            ? <span>{part},<br /></span>
            : <span class="text-primary">{part}</span>
        ))}
      </h1>

      <!-- Subheadline -->
      <p class="fade-in text-lg sm:text-xl text-white/80 mb-10 max-w-xl leading-relaxed">
        {hospitalInfo.subTagline}
      </p>

      <!-- CTAs -->
      <div class="fade-in flex flex-wrap gap-4">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold text-base px-8 py-4 rounded-full transition-all duration-300 shadow-2xl shadow-primary/30 hover:shadow-primary/50 hover:scale-105"
        >
          Book Appointment
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={`tel:${hospitalInfo.contact.emergency}`}
          class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white font-semibold text-base px-8 py-4 rounded-full transition-all duration-300 border border-white/20"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Emergency: {hospitalInfo.contact.emergencyDisplay}
        </a>
      </div>

      <!-- Stats -->
      <div class="fade-in mt-16 grid grid-cols-3 gap-6 max-w-md">
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-primary">24/7</div>
          <div class="text-xs sm:text-sm text-white/60 mt-1">ICU & Trauma</div>
        </div>
        <div class="text-center border-x border-white/10">
          <div class="text-3xl sm:text-4xl font-extrabold text-primary">5+</div>
          <div class="text-xs sm:text-sm text-white/60 mt-1">Departments</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-primary">100%</div>
          <div class="text-xs sm:text-sm text-white/60 mt-1">Sterilized OT</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden md:block">
    <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center pt-2">
      <div class="w-1.5 h-3 bg-white/60 rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
