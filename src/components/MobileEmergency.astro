---
import hospitalInfo from '../data/hospital-info.json';
---

<!-- Mobile Emergency Call Button -->
<div class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 md:hidden">
  <a
    href={`tel:${hospitalInfo.contact.emergency}`}
    class="pulse-emergency inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold text-sm px-6 py-3.5 rounded-full shadow-2xl transition-all duration-300"
  >
    <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    Emergency: {hospitalInfo.contact.emergencyDisplay}
  </a>
</div>
