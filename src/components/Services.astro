---
import hospitalInfo from '../data/hospital-info.json';

interface Department {
  name: string;
  description: string;
  icon: string;
  highlight: string | null;
}
---

<section id="services" class="py-12 lg:py-16 bg-light-gray">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-10 fade-in">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral mb-4">
        Services & <span class="text-secondary">Departments</span>
      </h2>
      <p class="text-neutral/60 text-base sm:text-lg">
        Comprehensive healthcare services designed to meet every medical need — from emergency trauma care to speciality diagnostics.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {hospitalInfo.departments.map((dept: Department, idx: number) => (
        <div class={`fade-in group relative bg-white rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-xl transition-all duration-500 border border-transparent hover:border-primary/20 ${idx === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
          {dept.highlight && (
            <div class="absolute top-4 right-4 bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full">
              {dept.highlight}
            </div>
          )}

          <div class="w-14 h-14 bg-gradient-to-br from-primary/15 to-secondary/15 rounded-2xl flex items-center justify-center text-3xl mb-5 group-hover:scale-110 transition-transform duration-300">
            {dept.icon}
          </div>

          <h3 class="text-xl font-bold text-neutral mb-3 group-hover:text-primary transition-colors">
            {dept.name}
          </h3>

          <p class="text-neutral/60 text-sm leading-relaxed">
            {dept.description}
          </p>


        </div>
      ))}
    </div>
  </div>
</section>
